{
  "name": "@flowdesk/tokens",
  "version": "0.3.0",
  "private": true,
  "description": "FlowDesk design tokens — the single source of truth for colors, spacing, and type. Consumed by every UI surface.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./tailwind-preset": "./src/tailwind-preset.ts",
    "./tokens.css": "./src/tokens.css",
    "./fonts.css": "./fonts/fonts.css"
  },
  "files": [
    "src",
    "fonts",
    "CONTRACT.md",
    "USAGE.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "20.14.15",
    "tailwindcss": "3.4.10",
    "typescript": "5.5.4"
  }
}
