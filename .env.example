# ──────────────────────────────────────────────────────────────────────────
# FlowDesk — environment configuration (EXAMPLE)
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# Every key below is part of the locked global contract (PRD #8 §10).
# ──────────────────────────────────────────────────────────────────────────

# ── Discord OAuth2 ─────────────────────────────────────────────────────────
# Auth source of truth = membership of the Flowjob.id guild + holding "DESK".
# OAuth scopes used by the API: identify, guilds.members.read
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
# Snowflake ID of the Flowjob.id Discord guild (server)
DISCORD_GUILD_ID=your_guild_snowflake_id
# Snowflake ID of the "DESK" role that grants terminal access
DISCORD_DESK_ROLE_ID=your_desk_role_snowflake_id

# ── Session cookie ─────────────────────────────────────────────────────────
# Used to sign the session cookie (HttpOnly + Secure + SameSite=Lax, 7d).
# Generate a long random string, e.g. `openssl rand -hex 32`.
SESSION_SECRET=change_me_to_a_long_random_string

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the API.
CORS_ORIGINS=http://localhost:3000

# ── Feed adapter ───────────────────────────────────────────────────────────
# historical = read cached Databento files from DATA_DIR; live = realtime stream.
# Flipping this value MUST NOT require code changes (PRD #8 AC-A3).
FEED_MODE=historical
# Databento API key (keep out of source control)
DATABENTO_API_KEY=db-xxxxxxxxxxxxxxxxxxxxxxxx
# Local directory holding cached raw option chains (.dbn / parquet)
DATA_DIR=/data/raw

# ── Datastores ─────────────────────────────────────────────────────────────
# TimescaleDB (Postgres) connection string — stores derived snapshots (90d).
TIMESCALE_DSN=postgres://flowdesk:flowdesk@localhost:5432/flowdesk
# Redis — "state now" per instrument + pub/sub push.
REDIS_URL=redis://localhost:6379/0

# ── Pricing input ──────────────────────────────────────────────────────────
# Daily SOFR rate. Black-76 uses r = ln(1 + SOFR).
SOFR_RATE=0.0531
